@model ControlTaxisApp.Models.Usuario

@{
    ViewData["Title"] = "Registro";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <h2 class="text-center">Crear Cuenta</h2>
            <form asp-action="Registro" method="post">
                <div class="form-group">
                    <label>Nombre de Usuario</label>
                    <input asp-for="NombreUsuario" class="form-control" required />
                </div>
                <div class="form-group mt-2">
                    <label>Contraseña</label>
                    <input asp-for="Clave" type="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary btn-block mt-3">Registrarse</button>
            </form>
            <p class="mt-3 text-center">¿Ya tienes cuenta? <a asp-action="Login">Inicia sesión</a></p>
        </div>
    </div>
</div>