@model IEnumerable<ControlTaxisApp.Models.Mantenimiento>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Historial de Mantenimientos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <div class="container my-5">
        <div class="card shadow-sm p-5 border-start border-success border-5 mb-4">
            <h2 class="fw-bold text-secondary">
                <i class="fa-solid fa-screwdriver-wrench text-success me-2"></i> Gestión de Mantenimientos y Taller
            </h2>
            <p class="text-muted">Registra y controla los gastos de reparaciones, cambios de aceite, repuestos y frenos de la flota.</p>
            <hr />
            <div class="d-flex justify-content-between">
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary btn-sm">
                    <i class="fa-solid fa-arrow-left me-1"></i> Volver al Inicio
                </a>
                <a asp-controller="Mantenimientos" asp-action="Crear" class="btn btn-success btn-sm">
                    <i class="fa-solid fa-plus me-1"></i> Registrar Gasto Taller
                </a>
            </div>
        </div>

        <form asp-action="Index" method="get" class="row g-3 mb-4 align-items-end">
            <div class="col-auto">
                <label class="form-label fw-bold small text-muted">Filtrar por Placa:</label>
                <select name="placaFiltro" class="form-select">
                    <option value="">-- Todas las Placas --</option>
                    @* Usamos 'dynamic' o simplemente iteramos el ViewBag directamente *@
                    @foreach (var item in ViewBag.Placas)
                    {
                        // Si ViewBag.Placas es un SelectList, accedemos a .Value y .Text
                        // Si es una lista de strings, usamos @item directamente
                        var valor = item.GetType().GetProperty("Value") != null ? item.Value : item.ToString();
                        var texto = item.GetType().GetProperty("Text") != null ? item.Text : item.ToString();

                        <option value="@valor" selected="@(valor == Context.Request.Query["placaFiltro"] ? "selected" : null)">
                            @texto
                        </option>
                    }
                </select>
            </div>

            <div class="col-auto">
                <select name="tipoId" class="form-select">
                    <option value="">-- Todos los Tipos --</option>
                    @foreach (var tipo in ViewBag.TiposFiltro)
                    {
                        <option value="@tipo.Id">@tipo.Nombre</option>
                    }
                </select>
            </div>

            <div class="col-auto d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-filter"></i> Filtrar
                </button>

               @*  <button type="submit" asp-action="GenerarReporteMantenimientoExcel" class="btn btn-success btn-sm">
                    <i class="fa-solid fa-file-excel"></i> Generar Reporte
                </button> *@

                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Limpiar</a>
            </div>
        </form>
        <div class="card shadow-sm p-4">
            <div class="table-responsive">
                <table id="tablaMantenimiento" class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha</th>
                            <th>Placa</th>
                            <th>Tipo Mantenimiento</th>
                            <th>Descripción</th>
                            <th>Kilometraje</th>
                            <th>Proximo Cambio</th>
                            <th>Taller</th>
                            <th>Costo ($)</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td data-order="@item.Fecha.ToString("yyyy-MM-dd")">@item.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td><span class="badge bg-warning text-dark fw-bold px-3 py-2 fs-6">@item.IdVehiculoNavigation?.Placa</span></td>
                                    <td>@item.TipoMantenimiento?.Nombre</td>
                                    <td>@item.Descripcion</td>
                                    <td>@item.Kilometraje</td>
                                    <td>@item.ProximoCambio</td>
                                    <td>@item.Taller</td>
                                    <td class="fw-bold text-danger">$@item.Valor.ToString("N0")</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen"></i></a>
                                            <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" onsubmit="return confirm('¿Eliminar este registro?');" style="display:inline;">
                                                <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted p-4">
                                    <i class="fa-solid fa-oil-can d-block fs-3 mb-2"></i>
                                    No se han registrado gastos de taller todavía.
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-secondary fw-bold">
                        <tr>
                            <td colspan="2" class="text-end">TOTALES</td>
                            <td></td>
                             <td></td>
                            <td></td>
                            <td></td>
                            <td>$@Model.Sum(x => x.Valor).ToString("N0")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
        $('#tablaMantenimiento').DataTable({
        "pageLength": 10, // Cantidad de registros por página
        "language": {
        "url": "//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json"
        },
        "order": [[0, "desc"]] // Ordenar por la primera columna (Fecha) de forma descendente
        });
        });
    </script>

</body>
</html>