@model ControlTaxisApp.Models.Mantenimiento
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registrar Mantenimiento</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <div class="container my-5" style="max-width: 600px;">
        <div class="card shadow-sm border-start border-success border-5 mb-4">
            <div class="card-body p-4">
                <h3 class="fw-bold text-secondary mb-1">
                    <i class="fa-solid fa-screwdriver-wrench text-success me-2"></i> Registrar Gasto Taller
                </h3>
                <p class="text-muted small">Ingresa los detalles de la reparación o mantenimiento del vehículo.</p>
                <hr />

                <form asp-action="Crear" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted">Seleccionar Vehículo / Placa</label>
                        <select asp-for="VehiculoId" class="form-select" asp-items="ViewBag.IdVehiculo" required>
                            <option value="">-- Seleccione una Placa --</option>
                        </select>
                        <span asp-validation-for="VehiculoId" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted">Fecha del Mantenimiento</label>
                        <input asp-for="Fecha" type="date" class="form-control" required />
                        <span asp-validation-for="Fecha" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted">Tipo de mantenimineto</label>
                    <select asp-for="TipoMantenimientoId" asp-items="ViewBag.Tipos" class="form-select">
                        <option value="">-- Seleccione un tipo --</option>
                    </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted">Descripción del Trabajo / Repuesto</label>
                        <textarea asp-for="Descripcion"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Ej: Cambio de aceite 10W-30, filtros y revisión de pastillas de freno delanteras..."
                                  style="resize: vertical;"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted">Costo del Trabajo ($)</label>
                        <input asp-for="Valor" type="number" step="0.01" class="form-control" required placeholder="Ej: 180000" />
                        <span asp-validation-for="Valor" class="text-danger small"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Kilometraje</label>
                            <input asp-for="Kilometraje" class="form-control" type="number" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>Próximo Cambio (Km)</label>
                            <input asp-for="ProximoCambio" class="form-control" type="number" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label>Nombre del Taller</label>
                        <input asp-for="Taller" class="form-control" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Garantía</label>
                            <input asp-for="Garantia" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>IVA ($)</label>
                            <input asp-for="Iva" class="form-control" type="number" step="0.01" />
                        </div>
                    </div>
                    <form asp-action="Crear" method="post">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Guardar Registro</button>
                        </div>
                    </form>
                </form>
            </div>
        </div>
    </div>
</body>
</html>