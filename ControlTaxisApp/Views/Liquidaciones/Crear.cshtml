@model ControlTaxisApp.Models.LiquidacionDiaria
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nueva Liquidación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <div class="container my-5" style="max-width: 600px;">
        <div class="card shadow-sm border-start border-success border-5">
            <div class="card-body p-4">
                <h3 class="fw-bold text-secondary mb-1">
                    <i class="fa-solid fa-plus text-success me-2"></i> Registrar Liquidación
                </h3>
                <hr />
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Vehículo</label>
                            <select asp-for="VehiculoId" class="form-select" asp-items="ViewBag.IdVehiculo">
                                <option value="">Seleccione un vehículo...</option>
                            </select>
                            <span asp-validation-for="VehiculoId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha de Labor</label>
                            <input asp-for="Fecha" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label">Estado del Día</label>
                            <select asp-for="EstadoDia" class="form-select">
                                <option value="NORMAL">Normal</option>
                                <option value="PICO_Y_PLACA">Pico y Placa</option>
                                <option value="TALLER">Día de Taller</option>
                                <option value="DESCANSO">Día de Descanso</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Producción ($)</label>
                            <input type="text" id="producidoVisual" class="form-control" oninput="formatearYCalcular(this, 'producidoReal')" />
                            <input asp-for="Producido" id="producidoReal" type="hidden" />
                        </div>
                        <!-- Campo Gastos -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Gastos ($)</label>
                            <input type="text" id="gastosVisual" class="form-control" oninput="formatearYCalcular(this, 'gastosReal')" />
                            <input asp-for="Gastos" id="gastosReal" type="hidden" />
                        </div>

                        <!-- Campo Ahorro -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Ahorro ($)</label>
                            <input type="text" id="ahorroVisual" class="form-control" oninput="formatearSolo(this, 'ahorroReal')" />
                            <input asp-for="Ahorro" id="ahorroReal" type="hidden" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Saldo Final ($)</label>
                            <input type="text" id="saldoDisplay" class="form-control" readonly />
                        </div>
                    </div>

                    <div class="text-end mt-3">
                        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-success">Guardar Liquidación</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script>
            // Función para campos que SI afectan el saldo (Producción y Gastos)
            function formatearYCalcular(input, idReal) {
                formatearSolo(input, idReal); // Primero formatea
                calcularSaldo();              // Luego recalcula el saldo
            }

            // Función para formatear y guardar en el hidden (usada por todos)
            function formatearSolo(input, idReal) {
                let valorLimpio = input.value.replace(/\D/g, '');
                document.getElementById(idReal).value = valorLimpio;

                if (valorLimpio !== "") {
                    input.value = new Intl.NumberFormat('es-CO').format(valorLimpio);
                } else {
                    input.value = "";
                }
            }

            // Función de cálculo (Ahorro NO está aquí porque no debe afectar el saldo)
            function calcularSaldo() {
                const prod = parseFloat(document.getElementById('producidoReal').value) || 0;
                const gast = parseFloat(document.getElementById('gastosReal').value) || 0;

                const saldo = prod - gast;

                document.getElementById('saldoDisplay').value = new Intl.NumberFormat('es-CO', {
                    style: 'currency',
                    currency: 'COP',
                    maximumFractionDigits: 0
                }).format(saldo);
            }
    </script>
</body>
</html>