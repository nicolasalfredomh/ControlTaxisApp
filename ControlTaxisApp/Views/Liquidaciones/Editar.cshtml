@model ControlTaxisApp.Models.LiquidacionDiaria
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar Liquidación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <div class="container my-5" style="max-width: 600px;">
        <div class="card shadow-sm border-start border-primary border-5 mb-4">
            <div class="card-body p-4">
                <h3 class="fw-bold text-secondary mb-1">
                    <i class="fa-solid fa-pen text-primary me-2"></i> Modificar Liquidación
                </h3>
                <p class="text-muted small">Corrige los valores de la planilla seleccionada.</p>
                <hr />

                <form asp-action="Editar" method="post" id="formEditar">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted">Seleccionar Vehículo / Placa</label>
                        <select asp-for="VehiculoId" class="form-select" asp-items="ViewBag.IdVehiculo" required>
                            <option value="">-- Seleccione una Placa --</option>
                        </select>
                    </div>
                    <div class="form-group mb-3">
                        <label class="control-label">¿Tiene Pico y Placa?</label>
                        <select asp-for="PicoYPlaca" class="form-select">
                            <option value="false">No</option>
                            <option value="true">Sí</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted">Monto de Producción ($)</label>
                        <input asp-for="Producido" id="producido" type="number" step="0.01" class="form-control" oninput="calcularSaldo()" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted">Gastos ($)</label>
                        <input asp-for="Gastos" id="gastos" type="number" step="0.01" class="form-control" oninput="calcularSaldo()" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted">Ahorro ($)</label>
                        <input asp-for="Ahorro" id="ahorro" type="number" step="0.01" class="form-control" oninput="calcularSaldo()" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold text-primary">Saldo Final ($)</label>

                        <input type="text" id="saldoDisplay" class="form-control fw-bold" readonly
                               value="@Model.Saldo" />

                        <input type="hidden" asp-for="Saldo" id="saldoHidden" />
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary btn-sm">Cancelar</a>
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fa-solid fa-floppy-disk me-1"></i> Actualizar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function calcularSaldo() {
            const prod = parseFloat(document.getElementById('producido').value.replace(',', '.')) || 0;
            const gast = parseFloat(document.getElementById('gastos').value.replace(',', '.')) || 0;
            const saldo = prod - gast;

            document.getElementById('saldoDisplay').value = saldo.toLocaleString('es-CO');
            document.getElementById('saldoHidden').value = saldo; // <--- Aquí guardamos el valor sin formato
        }

        // Interceptar el envío del formulario para asegurar que el valor esté presente
        document.getElementById('formEditar').addEventListener('submit', function() {
            const prod = parseFloat(document.getElementById('producido').value.replace(',', '.')) || 0;
            const gast = parseFloat(document.getElementById('gastos').value.replace(',', '.')) || 0;
            document.getElementById('saldoHidden').value = (prod - gast);
        });
    </script>
</body>
</html>