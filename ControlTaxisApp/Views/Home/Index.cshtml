@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel de Control - Flota de Taxis</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-warning" href="#">
                <i class="fa-solid fa-taxi me-2"></i>CONTROL DE FLOTA
            </a>
            <div class="d-flex align-items-center">

                <span class="text-white me-3">
                    <i class="fa-solid fa-user-check text-success me-1"></i> @User.Identity?.Name
                </span>
                <a class="btn btn-danger btn-sm" asp-controller="Acceso" asp-action="Salir">
                    <i class="fa-solid fa-right-from-bracket"></i> Salir
                </a>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <div class="p-5 mb-4 bg-white rounded-3 shadow-sm border-start border-warning border-5">
            <div class="container-fluid py-2">
                <h1 class="display-6 fw-bold text-secondary">Sistema de Gestión Comercial</h1>
                <p class="col-md-8 fs-6 text-muted">Administración automatizada de planillas diarias, ahorros y control de gastos por vehículo.</p>
            </div>
        </div>


        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-3 mx-auto mb-3" style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center;">
                            <i class="fa-solid fa-calculator fa-2x"></i>
                        </div>
                        <h5 class="card-title fw-bold text-dark">Liquidación Diaria</h5>
                        <p class="card-text text-muted small">Registra y controla el producido, gastos diarios y ahorros por placa de taxi.</p>
                        <a asp-controller="Liquidaciones" asp-action="Index" class="btn btn-warning text-dark btn-sm w-100 fw-bold mt-2">Gestionar Planillas</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <div class="bg-success bg-opacity-10 text-success rounded-circle p-3 mx-auto mb-3" style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center;">
                            <i class="fa-solid fa-wrench fa-2x"></i>
                        </div>
                        <h5 class="card-title fw-bold text-dark">Mantenimientos y Taller</h5>
                        <p class="card-text text-muted small">Controla los cambios de correa, reparaciones, kilometraje y alertas de repuestos.</p>
                        <a asp-controller="Mantenimientos" asp-action="Index" class="btn btn-success w-100">Ingresar al Taller</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3 mx-auto mb-3" style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center;">
                            <i class="fa-solid fa-car fa-2x"></i>
                        </div>
                        <h5 class="card-title fw-bold text-dark">Mis Taxis / Placas</h5>
                        <p class="card-text text-muted small">Administra los autos de la flota activa (VDR817, VER671, SWS031, etc.).</p>
                        <a asp-controller="Vehiculos" asp-action="Index" class="btn btn-primary w-100">Gestionar Flota</a>
                    </div>
                </div>
            </div>


            <div class="row mt-4 justify-content-center">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm border-top border-primary border-4">
                        <div class="card-body p-4 text-center">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3 mx-auto mb-3" style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-chart-line fa-2x"></i>
                            </div>
                            <h5 class="card-title fw-bold text-dark">Reportes Totales</h5>
                            <p class="card-text text-muted small">Visualiza el balance consolidado, ingresos por liquidaciones y gastos de mantenimiento.</p>
                            <a asp-controller="Reportes" asp-action="Index" class="btn btn-primary w-100 fw-bold">
                                <i class="fa-solid fa-file-invoice-dollar me-2"></i> Generar Reporte
                            </a>

                       
                        </div>
                    </div>
                </div>


                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm border-top border-dark border-4">
                        <div class="card-body p-4 text-center">
                            <div class="bg-primary bg-opacity-10 text-dark rounded-circle p-3 mx-auto mb-3" style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-chart-line fa-2x"></i>
                            </div>
                            <h5 class="card-title fw-bold text-dark">GASTOS ADMINISTRATIVOS</h5>
                            <p class="card-text text-muted small">Visualiza el balance consolidado, ingresos por gastos administrativos.</p>
                            <a asp-controller="GastosAdministrativos" asp-action="Index" class="btn btn-primary w-100 fw-bold">
                                <i class="fa-solid fa-file-invoice-dollar me-2"></i> GASTOS
                            </a>

                       
                        </div>
                    </div>
                </div>

            </div>


        </div>
    </div>

</body>
</html>