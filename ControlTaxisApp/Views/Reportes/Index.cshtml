@model ControlTaxisApp.Models.ViewModels.ReporteConsolidadoViewModel

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fa-solid fa-chart-line text-primary"></i> Reporte Consolidado</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Volver al Panel</a>
    </div>

    <div class="card p-3 mb-4 shadow-sm">
        <form method="get" class="row g-3 p-3 bg-light rounded shadow-sm mb-4">
            <div class="col-md-2">
                <label>Placa</label>
                <select name="placaFiltro" class="form-select" asp-items="ViewBag.Placas"><option value="">Todos</option></select>
            </div>
            <div class="col-md-2">
                <label>Mes</label>
                <select name="mes" class="form-select">
                    <option value="">Todo el año</option>
                    @{
                        string[] meses = { "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
                                        "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre" };
                        for (int i = 0; i < meses.Length; i++)
                        {
                            // El valor (value) es i+1 (1-12), el texto es el nombre
                            <option value="@(i + 1)">@meses[i]</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label>Año</label>
                <input type="number" name="anio" class="form-control" placeholder="2026" />
            </div>
            <div class="col-md-2">
                <label>Desde</label>
                <input type="date" name="fechaInicio" class="form-control" />
            </div>
            <div class="col-md-2">
                <label>Hasta</label>
                <input type="date" name="fechaFin" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Filtrar Reporte</button>
            </div>
        </form>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-success text-white p-3 shadow-sm">
                <h5>Total Ingresos</h5>
                <h3>@Model.TotalProducido.ToString("C0")</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white p-3 shadow-sm">
                <h5>Total Gastos</h5>
                <h3>@((Model.TotalGastosLiquidacion + Model.TotalGastosMantenimiento).ToString("C0"))</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-primary text-white p-3 shadow-sm">
                <h5>Utilidad Neta</h5>
                <h3>@Model.UtilidadNeta.ToString("C0")</h3>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <h4>Planillas de Liquidación</h4>
            <table class="table table-hover border">
                <thead class="table-light">
                    <tr>
                        <th>Placa</th>
                        <th>Producido</th>
                        <th>Gastos</th>
                        <th>Saldo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Liquidaciones)
                    {
                        <tr>
                            <td>@(item.Vehiculo?.Placa ?? "N/A")</td>
                            <td>@item.Producido.ToString("C0")</td>
                            <td>@(item.Gastos?.ToString("C0") ?? "$0")</td>
                            <td>@item.Saldo.ToString("C0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="col-md-6">
            <h4>Gastos de Mantenimiento</h4>
            <table class="table table-hover border">
                <thead class="table-light">
                    <tr>
                        <th>Placa</th>
                        <th>Descripción</th>
                        <th>Costo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Mantenimientos)
                    {
                        <tr>
                            <td>@(item.IdVehiculoNavigation?.Placa ?? "N/A")</td>
                            <td>@item.Descripcion</td>
                            <td>@item.Valor.ToString("C0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>