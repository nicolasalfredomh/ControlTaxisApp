@using ControlTaxisApp.Controllers
@using System.Globalization
@model ControlTaxisApp.Models.ViewModels.ReporteConsolidadoViewModel
@{
    var festivos = ViewBag.Festivos as List<DateTime> ?? new List<DateTime>();
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fa-solid fa-chart-line text-primary"></i> Reporte Consolidado</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Volver al Panel</a>
    </div>
</div>


    <div class="card p-3 mb-4 shadow-sm">
        <form method="get" class="row g-3 p-3 bg-light rounded shadow-sm mb-4">
            <div class="col-md-2">
                <label>Placa</label>
                <select name="placaFiltro" class="form-select" asp-items="ViewBag.Placas"><option value="">Todos</option></select>
            </div>
            <div class="col-md-2">
                <label>Mes</label>
                <select name="mes" class="form-select">
                    <option value="">Todo el año</option>
                    @{
                        string[] meses = { "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
                                        "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre" };
                        for (int i = 0; i < meses.Length; i++)
                        {
                            // El valor (value) es i+1 (1-12), el texto es el nombre
                            <option value="@(i + 1)">@meses[i]</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label>Año</label>
                <input type="number" name="anio" class="form-control" placeholder="2026" />
            </div>
            <div class="col-md-2">
                <label>Desde</label>
                <input type="date" name="fechaInicio" class="form-control" />
            </div>
            <div class="col-md-2">
                <label>Hasta</label>
                <input type="date" name="fechaFin" class="form-control" />
            </div>
            <div class="col-md-2">
                <label>Estado Dia</label>
            <select name="estadoFiltro" class="form-select">
                <option value="">Todos</option>
                <option value="NORMAL">Normal</option>
                <option value="PICO_Y_PLACA">Pico y Placa</option>
                <option value="TALLER">Taller</option>
                <option value="DESCANSO">Descanso</option>
            </select>
            </div>

            <!-- Filtro de Día Laboral -->
            <div class="col-md-2">
                <label>Tipo de Día</label>
                <select name="tipoDiaFiltro" class="form-select">
                    <option value="">Todos</option>
                    <option value="Habil">Hábil</option>
                    <option value="Festivo">Festivo</option>
                    <option value="Domingo">Domingo</option>
                </select>
            </div>

        <div class="col-md-3 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary flex-grow-1">
                <i class="fa-solid fa-filter"></i> Filtrar
            </button>

            <a asp-action="ExportarExcel"
               asp-all-route-data="Context.Request.Query.ToDictionary(k => k.Key, v => (string)v.Value)"
               class="btn btn-success flex-grow-1">
                <i class="fa-solid fa-file-excel"></i> Excel
            </a>
        </div>
        </form>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-success text-white p-3 shadow-sm">
                <h5>Total Ingresos</h5>
            <h3>@Model.TotalProducido.ToString("C0", new System.Globalization.CultureInfo("es-CO"))</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white p-3 shadow-sm">
                <h5>Total Gastos</h5>
            <h3>@((Model.TotalGastosLiquidacion).ToString("C0", new System.Globalization.CultureInfo("es-CO")))</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-primary text-white p-3 shadow-sm">
                <h5>Utilidad Neta</h5>
                <h3>@Model.UtilidadNeta.ToString("C0", new System.Globalization.CultureInfo("es-CO"))</h3>
            </div>
        </div>
    </div>
<div class="mb-3 p-3 border rounded bg-light">
<strong>Leyenda:</strong>
<ul class="list-inline mb-0 mt-2">
    <li class="list-inline-item"><span class="badge bg-danger">&nbsp;</span> Festivos y Domingos</li>
    <li class="list-inline-item"><span class="badge bg-primary">&nbsp;</span> Descanso</li>
    <li class="list-inline-item"><span class="badge bg-warning text-dark">&nbsp;</span> Pico y Placa</li>
    <li class="list-inline-item"><span class="badge bg-success">&nbsp;</span> Normal</li>
</ul>
</div>
    <div class="row">
        <div class="col-12 mb-4">
            <h4>Planillas de Liquidación</h4>
            <div class="table-responsive">  
            <table id="tablaLiquidaciones" class="table table-hover border w-100">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Placa</th>
                        <th>Producido</th>
                        <th>Gastos</th>
                        <th>Día Laboral</th> 
                        <th>Estado Dia</th>
                        <th>Saldo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Liquidaciones)
                    {

                        // 1. Verificamos si existe un mantenimiento para este día y este vehículo
                        bool tieneMantenimiento = Model.Mantenimientos.Any(m =>
                        m.Fecha.Date == item.Fecha.Date &&
                        m.VehiculoId == item.VehiculoId);

                        bool esDomingo = item.Fecha.DayOfWeek == DayOfWeek.Sunday;
                        bool esFestivo = ViewBag.Festivos != null && ((List<DateTime>)ViewBag.Festivos).Contains(item.Fecha.Date);

                        // Definimos el estilo de la fila
                        string filaClase = "";
                        string estiloFila = ""; // Para colores personalizados

                        if (esDomingo || esFestivo)
                        {
                            filaClase = "table-danger";
                        }
                        else
                        {
                            switch (item.EstadoDia)
                            {
                                case "TALLER":
                                    estiloFila = "background-color: #fd7e14; color: white;"; // Naranja vibrante
                                    break;
                                case "DESCANSO":
                                    filaClase = "table-primary";
                                    break;
                                case "PICO_Y_PLACA":
                                    filaClase = "table-warning";
                                    break;
                            }
                        }
                        <tr class="@filaClase" style="@estiloFila">
                            <td data-order="@item.Fecha.ToString("yyyy-MM-dd")">
                                <small class="d-block fw-bold">@item.Fecha.ToString("dd/MM/yyyy")</small>
                                <span class="text-muted">@item.Fecha.ToString("dddd", new System.Globalization.CultureInfo("es-ES")).ToUpper()</span>
                            </td>
                            <td>
                                @if (item.Vehiculo != null)
                                {
                                    @* Aquí quitamos el span con la clase badge y el if ternario *@
                                    <span class="badge bg-warning text-dark fw-bold px-3 py-2 fs-6">@item.Vehiculo.Placa</span>
                                }
                                else
                                {
                                    <span class="text-muted">ID: @item.VehiculoId</span>
                                }
                            </td>
                                <td>@item.Producido.ToString("C0", new System.Globalization.CultureInfo("es-CO"))</td>
                                <td>@(item.Gastos?.ToString("C0", new System.Globalization.CultureInfo("es-CO")) ?? "$0")</td>
                            <td>
                                @{
                                    // 1. Normalizamos a Date (00:00:00) para eliminar cualquier resto de hora
                                    DateTime fechaFiltro = item.Fecha.Date;

                                    // 2. Usamos .Any() para comparar explícitamente solo la fecha
                                    bool esDomingos = fechaFiltro.DayOfWeek == DayOfWeek.Sunday;
                                    bool esFestivos = festivos.Any(f => f.Date == fechaFiltro);
                                }
                                @if (esDomingos)
                                {
                                    <span class="badge bg-info text-dark">DOMINGO</span>
                                }
                                else if (esFestivos)
                                {

                                    <span class="badge bg-danger">FESTIVO</span>
                                }
                                else
                                {

                                    <span class="badge bg-success">HÁBIL</span>
                                }
                            </td>

                            <td>
                                @switch (item.EstadoDia)
                                {
                                    case "TALLER":
                                        <span class="badge bg-danger">TALLER</span>
                                        break;
                                    case "DESCANSO":

                                        <span class="badge bg-primary">DESCANSO</span>
                                        break;
                                    case "PICO_Y_PLACA":

                                        <span class="badge bg-warning text-dark">PICO Y PLACA</span>
                                        break;
                                    default:

                                        <span class="badge bg-success">NORMAL</span>
                                        break;
                                }
                            </td>
                                <td>@item.Saldo.ToString("C0", new System.Globalization.CultureInfo("es-CO"))</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
        <div class="col-12 mb-4">
            <h4>Gastos de Mantenimiento</h4>
            <div class="table-responsive">
            <table id="tablaMantenimientos" class="table table-hover border w-100">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Placa</th>
                        <th>Tipo Mnatenimiento</th>
                        <th>Descripción</th>
                        <th>Costo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Mantenimientos)
                    {
                        <tr>
                            <td data-order="@item.Fecha.ToString("yyyy-MM-dd")">
                                <small class="d-block fw-bold">@item.Fecha.ToString("dd/MM/yyyy")</small> 
                                <span class="text-muted">@item.Fecha.ToString("dddd", new System.Globalization.CultureInfo("es-ES")).ToUpper()</span>
                            </td>
                            <td>  <span class="badge bg-warning text-dark fw-bold px-3 py-2 fs-6"> @(item.IdVehiculoNavigation?.Placa ?? "N/A")</span></td>
                            <td>@(item.TipoMantenimiento?.Nombre ?? "N/A")</td>
                            <td>@item.Descripcion</td>                         
                            <td>@item.Valor.ToString("C0", new System.Globalization.CultureInfo("es-CO"))</td>
                        </tr>
                    }
                </tbody>
            </table>

            <h4>Gastos Administrativos</h4>
            <table id="tablaAdministrativos" class="table table-hover border w-100">
                <thead class="table-light">
                    <tr>
                    <th>Fecha</th>
                    <th>Placa</th>
                    <th>Concepto</th>
                    <th>Descripción</th>
                    <th>Costo</th>
                </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.GastosAdministrativos)
                    {
                        <tr>
                            <td data-order="@item.Fecha.ToString("yyyy-MM-dd")">
                                <small class="d-block fw-bold">@item.Fecha.ToString("dd/MM/yyyy")</small>
                                <span class="text-muted">@item.Fecha.ToString("dddd", new System.Globalization.CultureInfo("es-ES")).ToUpper()</span>
                            </td>
                            <td>  <span class="badge bg-warning text-dark fw-bold px-3 py-2 fs-6">@item.Placa</span></td>
                            <td>@item.Concepto</td><td>@item.Observaciones</td>
                            <td>@item.Valor.ToString("C0", new CultureInfo("es-CO"))</td></tr>
                    }
                </tbody>
            </table>

            @section Scripts {
                <script>
                    $(document).ready(function () {
                        $('#tablaLiquidaciones').DataTable({
                            "pageLength": 10,
                                        "order": [[0, "desc"]],
                            "language": { "url": "//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json" }
                        });
                        $('#tablaMantenimientos').DataTable({
                            "pageLength": 10,
                                        "order": [[0, "desc"]],
                            "language": { "url": "//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json" }
                        });
                                                 $('#tablaAdministrativos').DataTable({
                                        "pageLength": 10,
                                        "order": [[0, "desc"]],
                                        "language": { "url": "//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json" }
                                    });
                    });
                </script>
            }
        </div>
    </div>
</div>

